section.work

  //- Section header
  .work__header
    span.work__label // Work
    h2.work__title Selected Work

  //- Phase 2: Horizontal scroll — 3 project cards
  .work__h-outer
    .work__h-track

      //- Card 1: Vaultly
      .work__h-panel
        .work__h-img.work__h-img--vaultly
          img.work__h-img-photo(src="/vaultly.png" alt="Vaultly — Personal Wealth OS")
        .work__h-info
          span.work__h-type FINTECH PRODUCT • MOBILE EXPERIENCE
          h3.work__h-name Vaultly
          p.work__h-overview A fintech app that simplifies how people plan, track, and grow their wealth. Helping users build better financial habits through clarity and automation.
          .work__h-tags
            span.work__tag Product Design
            span.work__tag Mobile App
            span.work__tag Fintech

      //- Card 2: Brand Identity System
      .work__h-panel
        .work__h-img.work__h-img--vaultly
          img.work__h-img-photo(src="/MacBook13.jpg" alt="Brand Identity System")
        .work__h-info
          span.work__h-type SAAS PRODUCT • DASHBOARD EXPERIENCE
          h3.work__h-name FlowDeck Marketing Dashboard
          p.work__h-overview A scalable dashboard experience designed to simplify business insights and decision-making.
          .work__h-tags
            span.work__tag Product Design
            span.work__tag Design Systems
            span.work__tag SaaS

      //- Card 3: CTA
      .work__h-panel
        .work__h-img.work__h-img--vaultly
          img.work__h-img-photo(src="/MacBook13.jpg" alt="More Work")
        .work__h-info
          span.work__h-type Selected Work
          h3.work__h-name Want to see more?
          p.work__h-overview More case studies and detailed work available on request.
          .work__h-tags
            span.work__tag Product Design
            span.work__tag SaaS
            span.work__tag Dashboards
          .work__h-cta
            a.info-bar__cta.info-bar__cta--primary(href="#portfolio") Contact Me