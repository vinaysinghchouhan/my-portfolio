- const navLinks = ['Work', 'Process', 'About', 'Contact']

footer.footer
  //- Dome — position: fixed, scroll-driven via GSAP ScrollTrigger
  .footer__dome

  .footer__inner
    //- Top bar
    .footer__top
      a.footer__go-top(href="#" data-go-top) GO TO TOP

    //- Heading row: large heading left, CTA right
    .footer__heading-row
      h2.footer__heading
        | Let's Talk About#[br]Your Vision
      .footer__heading-aside
        a.footer__download-btn(href="#" download)
          | Download Resume
          svg(width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true")
            path(d="M7 1v8M3 6l4 4 4-4M2 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round")

    //- Info grid — 4 columns
    .footer__grid
      //- Col 1: Contact
      .footer__col
        .footer__group
          span.footer__label PHONE NUMBER
          span.footer__value +91 98765 43210
        .footer__group
          span.footer__label EMAIL
          a.footer__link(href="mailto:vinaysinghchouhan2@gmail.com") vinaysinghchouhan2@gmail.com
        .footer__group
          span.footer__label CURRENT RESIDENCE
          span.footer__value Jaipur, India

      //- Col 2: Socials
      .footer__col
        .footer__group
          span.footer__label SOCIALS
          a.footer__social-link(href="#") LinkedIn

      //- Col 3: Empty spacer
      .footer__col.footer__col--empty

      //- Col 4: Navigation
      .footer__col.footer__col--nav
        .footer__group
          span.footer__label NAVIGATION
          each item in navLinks
            a.footer__nav-link(href="#")= item

    //- Bottom bar
    .footer__bottom
      .footer__identity
        span.footer__name Vinay Singh Chouhan
        span.footer__role Design Lead & Product Designer
      span.footer__freelance Available for full-time opportunities
