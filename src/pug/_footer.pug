- const siteMapLinks = ['Home', 'Projects', 'About', 'Services', 'Process', 'Testimonials']
- const projectLinks = ['Brand Identity', 'UX Consulting', 'Web Design', 'App Design']
- const socialLinks = ['LinkedIn', 'Twitter', 'Instagram']

footer.footer
  //- Dome — position: fixed, scroll-driven via GSAP ScrollTrigger
  .footer__dome

  .footer__inner
    //- Top bar
    .footer__top
      a.footer__go-top(href="#" data-go-top) GO TO TOP
      .footer__meta
        span.footer__meta-line MADE BY VINAY SINGH CHOUHAN
        span.footer__meta-line LAST UPDATED 4/17/26
        span.footer__meta-line MADE IN VITE · PUG · GSAP
        span.footer__meta-line © ALL RIGHTS RESERVED

    //- Large heading
    h2.footer__heading
      | Let's Talk About#[br]Your Vision

    //- Info grid — 4 columns
    .footer__grid
      //- Col 1: Contact
      .footer__col
        .footer__group
          span.footer__label PHONE NUMBER
          span.footer__value +91 98765 43210
        .footer__group
          span.footer__label EMAIL
          a.footer__link(href="mailto:vinaysinghchouhan2@gmail.com") vinaysinghchouhan2@gmail.com
        .footer__group
          span.footer__label CURRENT RESIDENCE
          span.footer__value Jaipur, India
        .footer__group
          span.footer__label CURRENT TIME
          span.footer__clock

      //- Col 2: Socials
      .footer__col
        .footer__group
          span.footer__label SOCIALS
          each social in socialLinks
            a.footer__social-link(href="#")= social

      //- Col 3: Empty spacer
      .footer__col.footer__col--empty

      //- Col 4: Site map + Projects
      .footer__col.footer__col--nav
        .footer__group
          span.footer__label SITE MAP
          each item in siteMapLinks
            a.footer__nav-link(href="#")= item
        .footer__group
          span.footer__label PROJECTS
          each project in projectLinks
            a.footer__nav-link(href="#")= project

    //- Bottom bar
    .footer__bottom
      .footer__identity
        span.footer__name Vinay Singh Chouhan
        span.footer__role Design Lead & Product Designer
      span.footer__freelance AVAILABLE FOR FREELANCE
