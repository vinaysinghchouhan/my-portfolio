- const navLinks = [{label:'Home',href:'#home'},{label:'About',href:'#about'},{label:'Journey',href:'#journey'},{label:'Work',href:'#work'},{label:'Process',href:'#process'}]

footer#footer.footer
  //- Dome — position: fixed, scroll-driven via GSAP ScrollTrigger
  .footer__dome

  .footer__inner
    //- Top bar
    .footer__top
      a.footer__go-top(href="#" data-go-top) GO TO TOP

    //- Heading row: large heading left, CTA right
    .footer__heading-row
      h2.footer__heading
        | Let's Talk About#[br]Your Vision
      .footer__heading-aside
        a.footer__download-btn(href="https://drive.google.com/file/d/1Yc9qyocdu9czqXs1jF7FYeqsBC7kavvS/view?usp=sharing" target="_blank" rel="noopener noreferrer")
          | View Resume

    //- Info grid — 4 columns
    .footer__grid
      //- Col 1: Contact
      .footer__col
        .footer__group
          span.footer__label PHONE NUMBER
          a.footer__link(href="tel:8561058866") (+91) 8561058866
        .footer__group
          span.footer__label EMAIL
          a.footer__link(href="mailto:vinaysinghchouhan2@gmail.com") vinaysinghchouhan2@gmail.com
        .footer__group
          span.footer__label CURRENT RESIDENCE
          span.footer__value Jaipur, India

      //- Col 2: Socials
      .footer__col
        .footer__group
          span.footer__label SOCIALS
          a.footer__social-link(href="https://www.linkedin.com/in/vinay-singh-chouhan") LinkedIn

      //- Col 3: Empty spacer
      .footer__col.footer__col--empty

      //- Col 4: Navigation
      .footer__col.footer__col--nav
        .footer__group
          span.footer__label NAVIGATION
          each item in navLinks
            a.footer__nav-link(href=item.href)= item.label

    //- Bottom bar
    .footer__bottom
      .footer__identity
        //- span.footer__name Vinay Singh Chouhan
        span.footer__role Design Lead & Product Designer
      span.footer__freelance Available for full-time opportunities
