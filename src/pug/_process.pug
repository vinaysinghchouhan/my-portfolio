section.process
  .process__header
    .process__label // Process
    h2.process__title From idea to impact
    p.process__subtitle A structured yet flexible approach to designing scalable digital products

  .process__cards
    .process__card(data-step="01")
      .process__card-header
        .process__step 01
        h3.process__card-title Understand & Define

      .process__card-divider

      .process__card-body
        .process__card-label Discovery
        .process__card-content
          p.process__card-description I start by understanding user needs, business goals, and constraints — turning complexity into clear problem definitions.
          .process__card-tags
            span.process__tag User Research
            span.process__tag UX Thinking
            span.process__tag Product Understanding

    .process__card(data-step="02")
      .process__card-header
        .process__step 02
        h3.process__card-title Structure & Design

      .process__card-divider

      .process__card-body
        .process__card-label Design
        .process__card-content
          p.process__card-description I design intuitive flows, wireframes, and scalable UI systems focused on clarity, usability, and consistency.
          .process__card-tags
            span.process__tag UX/UI Design
            span.process__tag Design Systems
            span.process__tag Interaction Design

    .process__card(data-step="03")
