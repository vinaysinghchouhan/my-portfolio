section#journey.journey
  .journey__container
    .journey__header
      .journey__label // Journey
      h2.journey__title
        | From 
        span.journey__accent Execution 
        | to 
        span.journey__accent Product thinking

    .journey__timeline
      .journey__line

      .journey__cards
        .journey__card(data-card-index="0")
          .journey__card-content
            h3.journey__card-title Web & Graphic Designer
            p.journey__card-meta 2017 - 2018
            p.journey__card-description Started with visual and web design — building strong fundamentals in layout, usability, and interaction thinking.
            .journey__card-tags
              span.journey__tag Design Basics
              span.journey__tag Visual Design
              span.journey__tag Web Design

        .journey__card(data-card-index="1")
          .journey__card-content
            h3.journey__card-title Frontend Growth
            p.journey__card-meta 2018 - 2019
            p.journey__card-description Developed strong front-end skills with HTML & CSS, understanding how design translates into real interfaces
            .journey__card-tags
              span.journey__tag HTML
              span.journey__tag CSS
              span.journey__tag Responsive
              span.journey__tag WordPress
              span.journey__tag Web Layouts

        .journey__card(data-card-index="2")
          .journey__card-content
            h3.journey__card-title System Thinking
            p.journey__card-meta 2019 - 2020
            p.journey__card-description Optimized workflow by building reusable UI systems using PUG & SASS, focusing on scalability and consistency
            .journey__card-tags
              span.journey__tag PUG
              span.journey__tag SASS
              span.journey__tag BEM
              span.journey__tag ITCSS
              span.journey__tag GSAP
              span.journey__tag Reusable Systems

        .journey__card(data-card-index="3")
          .journey__card-content
            h3.journey__card-title UI/UX Designer
            p.journey__card-meta 2020 - 2022
            p.journey__card-description Shifted into UI/UX design, focusing on usability, user behavior, and creating intuitive digital experiences
            .journey__card-tags
              span.journey__tag UX Design
              span.journey__tag Usability
              span.journey__tag Interaction
              span.journey__tag Design Systems
              span.journey__tag Webflow
              span.journey__tag Framer

        .journey__card(data-card-index="4")
          .journey__card-content
            h3.journey__card-title Senior Design Consultant
            p.journey__card-meta 2022 - 2024
            p.journey__card-description Transitioned into product design — solving real user problems, collaborating with teams, and contributing to product strategy.
            .journey__card-tags
              span.journey__tag Consulting
              span.journey__tag Product Thinking
              span.journey__tag Strategy

        .journey__card(data-card-index="5")
          .journey__card-content
            h3.journey__card-title Design Lead
            p.journey__card-meta 2024 - Present
            p.journey__card-description Leading design initiatives, driving business impact, and building scalable, user-centric digital products
            .journey__card-tags
              span.journey__tag Leadership
              span.journey__tag Product Design
              span.journey__tag Business Impact
